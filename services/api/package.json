{
  "name": "@app-kd/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "echo \"No lint configured\"",
    "format": "echo \"No format configured\"",
    "db:push": "prisma db push --config prisma.config.ts",
    "db:backfill:customer-owner-store": "node scripts/backfill-customer-owner-store.mjs",
    "test:hard-ownership": "node scripts/verify-hard-ownership.mjs",
    "db:seed": "prisma db seed --config prisma.config.ts",
    "db:migrate:status": "prisma migrate status --config prisma.config.ts",
    "db:migrate:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:backfill:purchase-normalized": "node scripts/backfill-purchase-normalized.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.12",
    "prisma": "^6.6.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
